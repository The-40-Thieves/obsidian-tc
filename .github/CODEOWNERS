# where a returned array aliased live config — mutating it escalated privileges process-wide with
# no trace in the config file. Small diffs in these files are not low-risk diffs.
/packages/server/src/acl.ts                     @suavecito585
/packages/server/src/vault/acl-path.ts          @suavecito585
/packages/server/src/vault/acl-read-filter.ts   @suavecito585


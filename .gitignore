coverage/
.nyc_output/

# Cache
.cache/
.bun/
# obsidian-tc's local cache/trace dir. The default cacheDir is now ~/.obsidian-tc (absolute), but a
# CLI run with a relative cacheDir can still drop one here — ignore it so a stray cache.db (multi-MB)
# is never accidentally committed.
.obsidian-tc/

# Agent tooling (local only — never committed)
.omc/
.claude/

# Internal THE-233 migration-planning doc — kept local/private, never published.
MERGE-PROGRESS.md

# The golden set maps queries to REAL note paths in a personal vault — it is a map of that vault's
# contents (folder taxonomy, note titles, and what the author writes about). It is private data, not
# source. Keep it local; commit only multi-hop-golden-set.example.yaml.
packages/server/eval/multi-hop-golden-set.yaml
packages/server/eval/*-golden-set*.yaml
!packages/server/eval/multi-hop-golden-set.example.yaml
packages/server/eval/baseline.json

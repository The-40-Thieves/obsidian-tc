{
  "name": "obsidian-tc-monorepo",
  "version": "1.9.1",
  "private": true,
  "description": "Obsidian Turbocharged — comprehensive, model-agnostic, agent-ready Obsidian MCP server",
  "license": "AGPL-3.0-only",
  "author": "The 40 Thieves",
  "repository": {
    "type": "git",
    "url": "https://github.com/The-40-Thieves/obsidian-tc.git"
  },
  "homepage": "https://github.com/The-40-Thieves/obsidian-tc#readme",
  "bugs": {

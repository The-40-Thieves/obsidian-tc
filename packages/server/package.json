{
  "name": "obsidian-tc",
  "version": "1.0.2",
  "description": "MCP server for Obsidian — comprehensive tool surface for humans and autonomous agents",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "obsidian-tc": "./dist/cli.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "bun build ./src/index.ts ./src/cli.ts --outdir ./dist --target node && bun scripts/copy-assets.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "dev": "bun run --watch ./src/index.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@the-40-thieves/obsidian-tc-native": "workspace:*",
    "@the-40-thieves/obsidian-tc-shared": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "better-sqlite3": "^11.5.0",
    "fetch-to-node": "^2.1.0",
    "hono": "^4.6.0",
    "jose": "^6.2.3",
    "prom-client": "^15.1.3",
    "sqlite-vec": "^0.1.9",
    "yaml": "^2.6.1",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "vitest": "^2.1.0"
  },
  "keywords": ["obsidian", "mcp", "model-context-protocol", "knowledge-management", "agent", "ai"],
  "repository": {
    "type": "git",
    "url": "https://github.com/The-40-Thieves/obsidian-tc.git",
    "directory": "packages/server"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  }
}
